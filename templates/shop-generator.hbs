<form class="shop-generator-form" autocomplete="off">
  <div class="form-group">
    <label>Shop Type</label>
    <select name="shopType" required>
      <option value="general" selected>General Store</option>
      <option value="blacksmith">Blacksmith</option>
      <option value="alchemy">Alchemist</option>
      <option value="arcane">Arcane Dealer</option>
      <option value="fletcher">Fletcher / Bowyer</option>
      <option value="jeweler">Jeweler</option>
      <option value="herbalist">Herbalist</option>
      <option value="tavern">Tavern Supplies</option>
      <option value="stables">Stables &amp; Tack</option>
      <option value="leatherworker">Leatherworker</option>
      <option value="bookshop">Bookshop &amp; Scribe</option>
      <option value="curiosity">Curiosity Shop</option>
    </select>
  </div>

  <div class="form-group">
    <label>Settlement</label>
    <select name="settlement" required>
      <option value="hamlet">hamlet</option>
      <option value="village">village</option>
      <option value="town" selected>town</option>
      <option value="city">city</option>
      <option value="metropolis">metropolis</option>
    </select>
  </div>

  <div class="form-group">
    <label>Quality</label>
    <select name="quality" required>
      <option value="poor">poor</option>
      <option value="standard" selected>standard</option>
      <option value="luxury">luxury</option>
    </select>
  </div>

  <div class="form-group">
    <label>Item Count</label>
    <input type="number" name="itemCount" value="{{itemCount}}" min="1" max="100" placeholder="Auto" />
    <p class="notes">Leave blank to use the settlement size default.</p>
  </div>

  <div class="form-group">
    <label>Source Packs (CSV)</label>
    <input type="text" name="sourcePacks" value="{{sourcePacks}}" placeholder="dnd5e.items,world.magic-items" />
    <p class="notes">Use compendium IDs separated by commas.</p>
  </div>

  <div class="form-group">
    <label class="checkbox">
      <input type="checkbox" name="includeWorldItems" {{#if includeWorldItems}}checked{{/if}} />
      Include world items
    </label>
  </div>

  <div class="form-group">
    <label class="checkbox">
      <input type="checkbox" name="includeMagicItems" {{#if includeMagicItems}}checked{{/if}} />
      Include magic items
    </label>
    <p class="notes">Disable for mundane-only inventories.</p>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit" name="submit">
      <i class="fas fa-wand-magic-sparkles"></i> Generate Shop
    </button>
  </footer>
</form>
