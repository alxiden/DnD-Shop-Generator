<section class="shop-result">
  <header class="shop-header">
    <h2>{{name}}</h2>
    <p>
      <strong>Type:</strong> {{shopType}} |
      <strong>Settlement:</strong> {{settlement}} |
      <strong>Quality:</strong> {{quality}}
    </p>
  </header>

  <div class="shop-table-wrap">
    <table class="shop-table">
      <thead>
        <tr>
          <th>Item</th>
          <th>Type</th>
          <th>Rarity</th>
          <th>Price</th>
        </tr>
      </thead>
      <tbody>
        {{#each inventory as |item|}}
        <tr>
          <td>{{item.name}}</td>
          <td>{{item.type}}</td>
          <td>{{item.rarity}}</td>
          <td>{{item.displayPrice}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

  <footer class="shop-actions">
    <button type="button" data-action="save-journal">
      <i class="fas fa-book"></i> Save as Journal
    </button>
  </footer>
</section>
